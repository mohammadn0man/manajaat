{
  "cli": {
    "version": ">= 16.19.3",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "android": {
        "gradleCommand": ":app:bundleRelease"
      },
      "distribution": "store",
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {},
      "ios": {
        "ascAppId": "6759190231"
      }
    }
  }
}
